{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ES2022",
        "moduleResolution": "Bundler",
        "esModuleInterop": true,
        "strict": true,
        "skipLibCheck": true,
        "resolveJsonModule": true,
        "outDir": "./dist",
        "rootDir": ".",
        "declaration": true,
        "sourceMap": true
    },
    "include": ["src/**/*.ts", "bench/**/*.ts"],
    "exclude": [
        "node_modules",
        "dist",
        "poc",
        "arch-graph-out",
        "src/**/__fixtures__/**",
        "src/extractors/**/__fixtures__/**"
    ]
}
