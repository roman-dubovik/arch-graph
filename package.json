{
    "name": "arch-graph",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "description": "Static architecture graph for NestJS monorepos — NATS, BullMQ, TypeORM, DI, HTTP, TS imports.",
    "author": "Roman Dubovik",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/roman-dubovik/arch-graph"
    },
    "bin": {
        "arch-graph": "./bin/arch-graph"
    },
    "scripts": {
        "build": "tsc",
        "dev": "tsx src/cli/index.ts",
        "build:graph": "tsx src/cli/index.ts build",
        "init": "tsx src/cli/index.ts init",
        "diagnose": "tsx src/cli/index.ts diagnose",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage",
        "test:integration": "bash scripts/integration-test.sh",
        "test:integration:remote": "bash scripts/integration-test.sh --remote"
    },
    "dependencies": {
        "@dqbd/tiktoken": "^1.0.22",
        "@modelcontextprotocol/sdk": "^1.29.0",
        "@xenova/transformers": "^2.17.2",
        "fast-glob": "^3.3.2",
        "jiti": "^2.4.2",
        "js-yaml": "^4.1.1",
        "ts-morph": "^24.0.0",
        "zod": "^4.0.0"
    },
    "devDependencies": {
        "@types/js-yaml": "^4.0.9",
        "@types/node": "^20.0.0",
        "@vitest/coverage-v8": "^4.1.6",
        "tsx": "^4.7.0",
        "typescript": "^5.4.0",
        "vitest": "^4.1.6"
    },
    "overrides": {
        "protobufjs": "7.5.8"
    }
}
